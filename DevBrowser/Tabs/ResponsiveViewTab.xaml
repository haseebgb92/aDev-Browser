<UserControl x:Class="DevBrowser.Tabs.ResponsiveViewTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:DevBrowser.Views">
    <Grid Background="#121212">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <views:DevicePane x:Name="PaneLeft" Grid.Column="0" />
        <views:DevicePane x:Name="PaneCenter" Grid.Column="1" />
        <views:DevicePane x:Name="PaneRight" Grid.Column="2" />
    </Grid>
</UserControl>
